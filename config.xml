<Config>
  <AutostartName>initCmds</AutostartName>
  <PrintAutoCommands>T</PrintAutoCommands>
  <MaxOnelinerLength>125</MaxOnelinerLength>
  <ResponsePrintFormat>Normal</ResponsePrintFormat>
  <AutoCommands>
    <initCmds>
      <C0>loadall</C0>
      <C1>clear</C1>
      <C2>safemode on</C2>
      <C3>core new</C3>
      <C4>core migrate act own skipSame</C4>
      <C5>core destroy</C5>
      <C6>core activate</C6>
      <C8>loglevel all</C8>
    </initCmds>
<printWinKey>
    <W0>windows load --force</W0>
    <W1>windows msgs start</W1>
    <W2>hook manager start</W2>
    <W3>hook add delayed Print Keydown KeyUp</W3>
</printWinKey>
    <HelloWorld>
      <H0>windows load --force</H0>
      <H1>hook manager start</H1>
      <H2>sim keypress P R I N T</H2>
      <H3>sim keydown Space</H3>
      <H4>sim keyup Space</H4>
      <H5>sim keypress H E L L O</H5>
      <H6>sim keypress Enter</H6>
    </HelloWorld>
    <Shared>
      <Sh0>windows load --force</Sh0>
      <Sh1>windows msgs start</Sh1>
      <Sh2>core new comp packetsender</Sh2>
      <Sh3>network callback newconn print</Sh3>
      <Sh4>hook manager start</Sh4>
      <Sh5>load sclModules</Sh5>
      <Sh6>load joiners</Sh6>
      <Sh7>SIP force</Sh7>
    </Shared>
    <Client>
      <Cl0>auto run Shared</Cl0>
      <Cl1>pipeline new Recver NetworkCallbacks DDataSigner DInputSimulator exact=SHookManager</Cl1>
      <Cl2>network callback recv pipeline</Cl2>
      <Cl3>password add blue</Cl3>
      <Cl4>network hostlist</Cl4>
    </Client>
    <ServerPrep>
      <Se0>auto run Shared</Se0>
      <Se1>pipeline new ReadInputAndProcess DInputReader DInputMerger VScriptedInputProcessor</Se1>
      <Se2>pipeline new Sender DInputProcessor DDataSigner DPacketSender</Se2>
      <Se3>fm whitelist MorseCode.scl XAM5z0P9X1MwRmYLHQI/yP6MM5lB2StteLqaCWAAfwA=</Se3>
      <Se4>seclav parse MorseCode.scl</Se4>
      <Se5>SIP assign MorseCode.scl</Se5>
    </ServerPrep>
    <Server>
      <Se5>auto run ServerPrep</Se5>
      <Se6>password add blue</Se6>
      <Se7>target set 192.168.72.12:45256</Se7>
      <Se8>hook add fast Pipeline KeyDown KeyUp</Se8>
    </Server>
    <externClipboard>
      <ec0>fm whitelist InputResender.ExternalExtensions.dll 3NVdPEy9AHI/R+ATG9aLtdXak13KgW8FiElkXLzq81k=</ec0>
      <ec1>externals load InputResender.ExternalExtensions.dll ExternalClipboardLoader</ec1>
      <ec2>load-cmd-extClip</ec2>
      <ec3>clipboard -h</ec3>
    </externClipboard>
    <tapper>
      <ta00>tapper force A S D F Space CapsLock Scroll</ta00>
      <ta01>tapper wait 600</ta01>
      <ta02>tapper conditioon None</ta02>
      <ta03>tapper mapping Single X---- T</ta03>
      <ta04>tapper mapping Single -X--- A</ta04>
      <ta05>tapper mapping Single --X-- E</ta05>
      <ta06>tapper mapping Single ---X- I</ta06>
      <ta07>tapper mapping Single ----X O</ta07>
      <ta08>tapper mapping Single XX--- D</ta08>
      <ta09>tapper mapping Single X-X-- U</ta09>
      <ta10>tapper mapping Single X--X- P</ta10>
      <ta11>tapper mapping Single X---X M</ta11>
      <ta12>tapper mapping Single -XX-- N</ta12>
      <ta13>tapper mapping Single -X-X- R</ta13>
      <ta14>tapper mapping Single -X--X B</ta14>
      <ta15>tapper mapping Single --XX- S</ta15>
      <ta16>tapper mapping Single --X-X Space</ta16>
      <ta17>tapper mapping Single ---XX F</ta17>
      <ta18>tapper mapping Single XXXXX C</ta18>
      <ta19>tapper mapping Single -XXXX L</ta19>
      <ta20>tapper mapping Single X-XXX G</ta20>
      <ta21>tapper mapping Single XX-XX Z</ta21>
      <ta22>tapper mapping Single XXX-X Enter</ta22>
      <ta23>tapper mapping Single XXXX- J</ta23>
      <ta24>tapper mapping Single --XXX Scroll None</ta24>
      <ta25>tapper mapping Single -X-XX Y</ta25>
      <ta26>tapper mapping Single -XX-X Down</ta26>
      <ta27>tapper mapping Single -XXX- K</ta27>
      <ta28>tapper mapping Single X--XX V</ta28>
      <ta29>tapper mapping Single X-X-X Q</ta29>
      <ta30>tapper mapping Single X-XX- H</ta30>
      <ta31>tapper mapping Single XX--X X</ta31>
      <ta32>tapper mapping Single XX-X- W</ta32>
      <ta33>tapper mapping Single XXX-- CapsLock None</ta33>
