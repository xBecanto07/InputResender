@page "/counter"
@using Components.Library
@rendermode InteractiveServer

<PageTitle>Counter</PageTitle>

<h1>Counter</h1>

<p role="status">Current count: @currentCount</p>
<p role="status">ASDF: @asdf</p>

<button class="btn btn-primary" @onclick="IncrementCount">Click me</button>

@code {
    [CascadingParameter(Name = "EnviHolder")]
    private EnvironmentHolder EnvHolder { get; set; }
    private CoreBase MyOwner;

    private int currentCount = 0;
    private string asdf = "ASDF";

    protected override void OnInitialized () {
        MyOwner = EnvHolder.OwnerCore;
    }

    private void IncrementCount () {
        currentCount++;
        if (MyOwner == null)
            asdf = "Owner is null";
        else {
            asdf = $"Owner is: {MyOwner.Name} (#{MyOwner.CoreID})";
        }
    }
}